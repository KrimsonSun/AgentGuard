# ⚠️ 注释永远独立成行，不要写在 KEY=VALUE 同一行（dotenv 会把行内注释当值读进去）

# ============ OpenRouter（LLM 大脑） ============
OPENROUTER_API_KEY=
# 模型不在此硬编码——用 Admin Console 运行时切换（uvicorn admin.server:app --port 8100）
# 下面只是 DB 不可用时的兜底值，可留空
OPENROUTER_MODEL=

# ============ LiveKit（实时媒体 + WebRTC 呼入，Cloud 免费档即可） ============
# 形如 wss://your-project.livekit.cloud
LIVEKIT_URL=
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ============ 中文流式 STT / TTS（Day1 双方向实测后定稿） ============
# 候选：volc(火山) / aliyun / tencent / deepgram / cartesia
STT_PROVIDER=
STT_API_KEY=
TTS_PROVIDER=
TTS_API_KEY=

# ============ Neon Postgres（记忆/配置/台账 事实源） ============
# 形如 postgresql://user:pwd@ep-xxx.neon.tech/agentguard?sslmode=require
DATABASE_URL=

# ============ 企业微信（保安推送） ============
# 群机器人 webhook（MVP 单向推送），形如 https://qyapi.weixin.qq.com/cgi-bin/webhook/send?key=xxx
WECOM_WEBHOOK_URL=

# ---- 双向交互（保安点按钮放行，可选升级）需自建应用+回调 ----
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_APP_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=

# ============ SIP/PSTN 生产路径（可选，见 HANDOFF §决策3 v2） ============
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=
TWILIO_SIP_TRUNK_DOMAIN=
