# ============ OpenRouter（LLM 大脑） ============
OPENROUTER_API_KEY=
# 模型 Day1-2 spike 定稿；候选：快且中文强的模型
#   google/gemini-2.x-flash · qwen/qwen-*-instruct · openai/gpt-*-mini
OPENROUTER_MODEL=
# 计费对账：请求携带 usage，必要时 GET /api/v1/generation?id= 取精确原生 token 与 total_cost

# ============ Twilio（电话接入） ============
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=          # 购买的号码，E.164，如 +1XXXXXXXXXX
TWILIO_SIP_TRUNK_DOMAIN=      # SIP 域（走 SIP ingress 到 LiveKit）

# ============ LiveKit（实时媒体，常驻主机） ============
LIVEKIT_URL=                 # wss://your-project.livekit.cloud 或自建
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=

# ============ STT / TTS（中文·流式，provider Day1-2 spike 定） ============
STT_PROVIDER=                # 如 deepgram / qwen-asr / volc(火山) ...
STT_API_KEY=
TTS_PROVIDER=                # 如 qwen-tts / minimax / volc / elevenlabs ...
TTS_API_KEY=

# ============ Neon Postgres（记忆 / 事实源） ============
DATABASE_URL=                # postgres://user:pwd@ep-xxx.neon.tech/agentguard?sslmode=require

# ============ 企业微信（保安推送） ============
WECOM_WEBHOOK_URL=           # 群机器人 webhook（MVP，单向推送）
# —— 双向交互（保安点按钮放行）需自建应用+回调，可选升级 ——
WECOM_CORP_ID=
WECOM_AGENT_ID=
WECOM_APP_SECRET=
WECOM_CALLBACK_TOKEN=
WECOM_CALLBACK_AES_KEY=
